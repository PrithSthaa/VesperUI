    local function ToggleUI()
        minimized = not minimized
        if minimized then
            TweenPlay(Scale, {Scale = 0}, 0.28, Enum.EasingStyle.Back, Enum.EasingDirection.In)
            task.delay(0.28, function() Main.Visible = false end)
        else
            Main.Visible = true
            TweenPlay(Scale, {Scale = 1}, 0.45, Enum.EasingStyle.Elastic)
        end
    end

    -- Animate in on start
    Main.Visible = true
    TweenPlay(Scale, {Scale = 1}, 0.5, Enum.EasingStyle.Elastic)

    BubbleBtn.MouseButton1Click:Connect(ToggleUI)
    MinBtn.MouseButton1Click:Connect(ToggleUI)
    CloseBtn.MouseButton1Click:Connect(function()
        TweenPlay(Scale, {Scale = 0}, 0.22, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        task.delay(0.22, function() Main.Visible = false end)
    end)
    UIS.InputBegan:Connect(function(i, p)
        if not p and i.KeyCode == keybind then ToggleUI() end
    end)

    function Window:Toggle(state)
        if state ~= nil then
            if state == (not minimized) then return end
        end
        ToggleUI()
    end

