            old._btnSub.TextColor3   = theme.Muted
            old._page.Visible = false
        end
        -- Activate new
        Window._active = tabObj
        TweenPlay(tabObj._btn, {BackgroundColor3 = theme.SidebarItemHover}, 0.18)
        TweenPlay(tabObj._indicator, {BackgroundTransparency = 0, Size = UDim2.new(0, 3, 0.65, 0)}, 0.22, Enum.EasingStyle.Back)
