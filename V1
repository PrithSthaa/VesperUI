                CNL.TextColor3 = theme.Text
                CNL.TextSize   = 12
                CNL.TextXAlignment = Enum.TextXAlignment.Left
                CNL.TextTruncate = Enum.TextTruncate.AtEnd

                local Preview = Instance.new("Frame", CHeader)
                Preview.BackgroundColor3 = color
                Preview.AnchorPoint = Vector2.new(1, 0.5)
                Preview.Position    = UDim2.new(1, -10, 0.5, 0)
                Preview.Size        = UDim2.new(0, 38, 0, 18)
                AddCorner(Preview, 5)
                AddStroke(Preview, theme.Border, 1)

                -- Picker panel
                local PickPanel = Instance.new("Frame", CWrap)
                PickPanel.BackgroundTransparency = 1
                PickPanel.Position = UDim2.new(0, 8, 0, 38)
                PickPanel.Size     = UDim2.new(1, -16, 0, 120)

                -- SV map
                local SVMap = Instance.new("TextButton", PickPanel)
                SVMap.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                SVMap.Position = UDim2.new(0, 0, 0, 0)
                SVMap.Size     = UDim2.new(1, -22, 0, 110)
                SVMap.Text     = ""
                SVMap.AutoButtonColor = false
                AddCorner(SVMap, 5)

                local WhiteGrad = Instance.new("UIGradient", SVMap)
                WhiteGrad.Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1)
                })
                WhiteGrad.Color = ColorSequence.new(Color3.new(1,1,1))

                local BlackOv = Instance.new("Frame", SVMap)
                BlackOv.BackgroundColor3 = Color3.new(0,0,0)
                BlackOv.BorderSizePixel  = 0
                BlackOv.Size = UDim2.new(1, 0, 1, 0)
                AddCorner(BlackOv, 5)
                local BlackGrad = Instance.new("UIGradient", BlackOv)
                BlackGrad.Rotation    = 90
                BlackGrad.Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(1, 0)
                })

                local SVCursor = Instance.new("Frame", SVMap)
                SVCursor.BackgroundColor3 = Color3.new(1,1,1)
                SVCursor.AnchorPoint = Vector2.new(0.5, 0.5)
                SVCursor.Position    = UDim2.new(s, 0, 1 - v, 0)
                SVCursor.Size        = UDim2.new(0, 8, 0, 8)
                SVCursor.ZIndex      = 5
                AddCorner(SVCursor, 100)
                AddStroke(SVCursor, Color3.new(0,0,0), 1, 0.4)

                -- Hue bar
                local HueBar = Instance.new("TextButton", PickPanel)
                HueBar.BackgroundColor3 = Color3.new(1,1,1)
                HueBar.AnchorPoint = Vector2.new(1, 0)
                HueBar.Position    = UDim2.new(1, 0, 0, 0)
                HueBar.Size        = UDim2.new(0, 14, 0, 110)
                HueBar.Text        = ""
                HueBar.AutoButtonColor = false
                AddCorner(HueBar, 6)
                local HueGrad = Instance.new("UIGradient", HueBar)
                HueGrad.Rotation = 90
                HueGrad.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0,    Color3.fromRGB(255, 0, 0)),
                    ColorSequenceKeypoint.new(0.167, Color3.fromRGB(255, 255, 0)),
                    ColorSequenceKeypoint.new(0.333, Color3.fromRGB(0, 255, 0)),
                    ColorSequenceKeypoint.new(0.5,  Color3.fromRGB(0, 255, 255)),
                    ColorSequenceKeypoint.new(0.667, Color3.fromRGB(0, 0, 255)),
                    ColorSequenceKeypoint.new(0.833, Color3.fromRGB(255, 0, 255)),
                    ColorSequenceKeypoint.new(1,    Color3.fromRGB(255, 0, 0)),
                })

                local HueCursor = Instance.new("Frame", HueBar)
                HueCursor.BackgroundColor3 = Color3.new(1,1,1)
                HueCursor.AnchorPoint = Vector2.new(0.5, 0.5)
                HueCursor.Position    = UDim2.new(0.5, 0, h, 0)
                HueCursor.Size        = UDim2.new(1, 4, 0, 4)
                HueCursor.ZIndex      = 5
                AddCorner(HueCursor, 100)
                AddStroke(HueCursor, Color3.new(0,0,0), 1, 0.4)

                -- Hex input
                local HexRow = Instance.new("Frame", PickPanel)
                HexRow.BackgroundTransparency = 1
                HexRow.Position = UDim2.new(0, 0, 0, 114)
                HexRow.Size     = UDim2.new(1, -22, 0, 20)

                local HexBg = Instance.new("Frame", HexRow)
                HexBg.BackgroundColor3 = theme.InputBg
                HexBg.BorderSizePixel  = 0
                HexBg.Size = UDim2.new(1, 0, 1, 0)
                AddCorner(HexBg, 4)

                local HexLabel = Instance.new("TextLabel", HexBg)
                HexLabel.BackgroundTransparency = 1
                HexLabel.Position = UDim2.new(0, 6, 0, 0)
                HexLabel.Size     = UDim2.new(0, 14, 1, 0)
                HexLabel.Font     = Enum.Font.GothamBold
                HexLabel.Text     = "#"
                HexLabel.TextColor3 = theme.Muted
                HexLabel.TextSize   = 10

                local HexBox = Instance.new("TextBox", HexBg)
                HexBox.BackgroundTransparency = 1
                HexBox.Position = UDim2.new(0, 20, 0, 0)
                HexBox.Size     = UDim2.new(1, -26, 1, 0)
                HexBox.Font     = Enum.Font.Gotham
                HexBox.Text     = string.format("%02X%02X%02X",
                    math.floor(color.R*255), math.floor(color.G*255), math.floor(color.B*255))
                HexBox.TextColor3 = theme.Text
                HexBox.TextSize   = 10
                HexBox.ClearTextOnFocus = false

                local function UpdateColor()
                    color = Color3.fromHSV(h, s, v)
                    SVMap.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                    Preview.BackgroundColor3 = color
                    HexBox.Text = string.format("%02X%02X%02X",
                        math.floor(color.R*255), math.floor(color.G*255), math.floor(color.B*255))
                    task.spawn(cb, color)
                end

                local trackSV, trackHue = false, false
                local function pct(i, obj, axis)
                    if axis == "X" then
                        return math.clamp((i.Position.X - obj.AbsolutePosition.X)/obj.AbsoluteSize.X, 0, 1)
                    end
                    return math.clamp((i.Position.Y - obj.AbsolutePosition.Y)/obj.AbsoluteSize.Y, 0, 1)
                end

                SVMap.InputBegan:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then
                        trackSV = true
                        s = pct(i, SVMap, "X"); v = 1 - pct(i, SVMap, "Y")
                        SVCursor.Position = UDim2.new(s, 0, 1-v, 0); UpdateColor()
                    end
                end)
                HueBar.InputBegan:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then
                        trackHue = true
                        h = pct(i, HueBar, "Y")
                        HueCursor.Position = UDim2.new(0.5, 0, h, 0); UpdateColor()
                    end
                end)
                UIS.InputEnded:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then
                        trackSV = false; trackHue = false
                    end
                end)
                UIS.InputChanged:Connect(function(i)
                    if i.UserInputType ~= Enum.UserInputType.MouseMovement then return end
                    if trackSV then
                        s = pct(i, SVMap, "X"); v = 1 - pct(i, SVMap, "Y")
                        SVCursor.Position = UDim2.new(s, 0, 1-v, 0); UpdateColor()
                    elseif trackHue then
                        h = pct(i, HueBar, "Y")
                        HueCursor.Position = UDim2.new(0.5, 0, h, 0); UpdateColor()
                    end
                end)

                HexBox.FocusLost:Connect(function()
                    local hex = HexBox.Text:gsub("[^%x]", ""):sub(1, 6)
                    if #hex == 6 then
                        local r = tonumber(hex:sub(1,2), 16)/255
                        local g = tonumber(hex:sub(3,4), 16)/255
                        local b = tonumber(hex:sub(5,6), 16)/255
                        h, s, v = Color3.new(r,g,b):ToHSV()
                        SVCursor.Position  = UDim2.new(s, 0, 1-v, 0)
                        HueCursor.Position = UDim2.new(0.5, 0, h, 0)
                        UpdateColor()
                    end
                end)

                CHeader.MouseButton1Click:Connect(function()
                    isOpen = not isOpen
                    local h2 = isOpen and 170 or 32
                    TweenPlay(CWrap, {Size = UDim2.new(1, 0, 0, h2)}, 0.22, Enum.EasingStyle.Back)
                end)

                local API = {}
                function API:Set(c)
                    color = c
                    h, s, v = c:ToHSV()
                    SVCursor.Position  = UDim2.new(s, 0, 1-v, 0)
                    HueCursor.Position = UDim2.new(0.5, 0, h, 0)
                    UpdateColor()
                end
                function API:Get() return color end
                return API
            end

            return SectionAPI
        end

        return TabAPI
    end

