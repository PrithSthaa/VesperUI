                Track.Size        = UDim2.new(0, 36, 0, 20)
                Track.BackgroundColor3 = toggled and theme.Accent or theme.TrackBg
                AddCorner(Track, 100)

                local Knob = Instance.new("Frame", Track)
                Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                Knob.AnchorPoint = Vector2.new(0, 0.5)
                Knob.Position    = UDim2.new(0, toggled and 18 or 2, 0.5, 0)
                Knob.Size        = UDim2.new(0, 16, 0, 16)
                AddCorner(Knob, 100)

                local function Refresh(val)
                    TweenPlay(Track, {BackgroundColor3 = val and theme.Accent or theme.TrackBg}, 0.2)
                    TweenPlay(Knob, {Position = UDim2.new(0, val and 18 or 2, 0.5, 0)}, 0.22, Enum.EasingStyle.Back)
                end

                Row.MouseButton1Click:Connect(function()
                    toggled = not toggled
                    Refresh(toggled)
                    task.spawn(cb, toggled)
                end)

                local API = {}
                function API:Set(val)
                    if toggled == val then return end
                    toggled = val
                    Refresh(val)
                    task.spawn(cb, val)
                end
                function API:Get() return toggled end
                return API
            end

            -- ── Slider ────────────────────────────
            function SectionAPI:CreateSlider(name, opts, callback)
                local min     = opts.Min     or 0
                local max     = opts.Max     or 100
                local default = opts.Default or min
                local step    = opts.Step    or 1
                local suffix  = opts.Suffix  or ""
                local cb      = callback or function() end
                local val     = default

                local F = Instance.new("Frame", EContainer)
                F.BackgroundColor3 = theme.SurfaceHigh
                F.BorderSizePixel  = 0
                F.Size = UDim2.new(1, 0, 0, 50)
                AddCorner(F, 6)
                AddStroke(F, theme.Border, 1)

                local NL = Instance.new("TextLabel", F)
                NL.BackgroundTransparency = 1
                NL.Position = UDim2.new(0, 10, 0, 8)
                NL.Size     = UDim2.new(0.65, 0, 0, 16)
                NL.Font     = Enum.Font.GothamBold
                NL.Text     = name
                NL.TextColor3 = theme.Text
                NL.TextSize   = 12
                NL.TextXAlignment = Enum.TextXAlignment.Left

                local VL = Instance.new("TextLabel", F)
                VL.BackgroundTransparency = 1
                VL.Position = UDim2.new(0.65, 0, 0, 8)
                VL.Size     = UDim2.new(0.35, -10, 0, 16)
                VL.Font     = Enum.Font.GothamBold
                VL.Text     = tostring(val) .. suffix
                VL.TextColor3 = theme.Accent
                VL.TextSize   = 12
                VL.TextXAlignment = Enum.TextXAlignment.Right

                local Track = Instance.new("TextButton", F)
                Track.BackgroundColor3 = theme.TrackBg
                Track.BorderSizePixel  = 0
                Track.Position = UDim2.new(0, 10, 0, 32)
                Track.Size     = UDim2.new(1, -20, 0, 8)
                Track.Text     = ""
                Track.AutoButtonColor = false
                AddCorner(Track, 100)

                local Fill = Instance.new("Frame", Track)
                Fill.BackgroundColor3 = theme.Accent
                Fill.Size = UDim2.new((val - min) / (max - min), 0, 1, 0)
                Fill.BorderSizePixel = 0
                AddCorner(Fill, 100)

                -- Glow on fill end
                local FillGlow = Instance.new("ImageLabel", Fill)
                FillGlow.BackgroundTransparency = 1
                FillGlow.AnchorPoint = Vector2.new(1, 0.5)
                FillGlow.Position    = UDim2.new(1, 0, 0.5, 0)
                FillGlow.Size        = UDim2.new(0, 22, 0, 22)
                FillGlow.Image       = "rbxassetid://4996891970"
                FillGlow.ImageColor3 = theme.Accent
                FillGlow.ImageTransparency = 0.5

                local Knob = Instance.new("Frame", Track)
                Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                Knob.AnchorPoint = Vector2.new(0.5, 0.5)
                Knob.Position    = UDim2.new((val - min) / (max - min), 0, 0.5, 0)
                Knob.Size        = UDim2.new(0, 14, 0, 14)
                AddCorner(Knob, 100)
                AddStroke(Knob, Color3.new(0,0,0), 1, 0.7)

                local dragging = false
                local function SetVal(px)
                    local pct = math.clamp((px - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                    local raw = min + (max - min) * pct
                    local stepped = math.round(raw / step) * step
                    val = math.clamp(stepped, min, max)
                    local p = (val - min) / (max - min)
                    TweenPlay(Fill, {Size = UDim2.new(p, 0, 1, 0)}, 0.05)
                    TweenPlay(Knob, {Position = UDim2.new(p, 0, 0.5, 0)}, 0.05)
                    VL.Text = tostring(val) .. suffix
                    task.spawn(cb, val)
                end

                Track.InputBegan:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = true; SetVal(i.Position.X)
                    end
                end)
                UIS.InputEnded:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
                end)
                UIS.InputChanged:Connect(function(i)
                    if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
                        SetVal(i.Position.X)
                    end
                end)

                local API = {}
                function API:Set(v)
                    val = math.clamp(v, min, max)
                    local p = (val - min) / (max - min)
                    TweenPlay(Fill, {Size = UDim2.new(p, 0, 1, 0)}, 0.1)
                    TweenPlay(Knob, {Position = UDim2.new(p, 0, 0.5, 0)}, 0.1)
                    VL.Text = tostring(val) .. suffix
                end
                function API:Get() return val end
                return API
            end

            -- ── Dropdown ──────────────────────────
            function SectionAPI:CreateDropdown(name, items, multi, callback)
                local cb       = callback or function() end
                local isOpen   = false
                local selected = {}  -- always a table
                local MAX_VISIBLE = 5

                local DropWrap = Instance.new("Frame", EContainer)
                DropWrap.BackgroundColor3 = theme.SurfaceHigh
                DropWrap.BorderSizePixel  = 0
                DropWrap.Size  = UDim2.new(1, 0, 0, 32)
                DropWrap.ClipsDescendants = false
                DropWrap.ZIndex = 5
                AddCorner(DropWrap, 6)
                AddStroke(DropWrap, theme.Border, 1)

                local Header2 = Instance.new("TextButton", DropWrap)
                Header2.BackgroundTransparency = 1
                Header2.Size = UDim2.new(1, 0, 0, 32)
                Header2.Text = ""
                Header2.AutoButtonColor = false
                Header2.ZIndex = 5

                local DName = Instance.new("TextLabel", Header2)
                DName.BackgroundTransparency = 1
                DName.Position = UDim2.new(0, 10, 0, 0)
                DName.Size     = UDim2.new(0.55, 0, 1, 0)
                DName.Font     = Enum.Font.GothamBold
                DName.Text     = name
                DName.TextColor3 = theme.Text
                DName.TextSize   = 12
                DName.TextXAlignment = Enum.TextXAlignment.Left
                DName.TextTruncate = Enum.TextTruncate.AtEnd
                DName.ZIndex = 5

                local DVal = Instance.new("TextLabel", Header2)
                DVal.BackgroundTransparency = 1
                DVal.AnchorPoint = Vector2.new(1, 0.5)
                DVal.Position    = UDim2.new(1, -30, 0.5, 0)
                DVal.Size        = UDim2.new(0.45, -35, 0, 14)
                DVal.Font        = Enum.Font.Gotham
                DVal.Text        = multi and "None" or "Select..."
                DVal.TextColor3  = theme.Accent
                DVal.TextSize    = 11
                DVal.TextXAlignment = Enum.TextXAlignment.Right
                DVal.TextTruncate = Enum.TextTruncate.AtEnd
                DVal.ZIndex = 5

                local DChev = Instance.new("ImageLabel", Header2)
                DChev.BackgroundTransparency = 1
                DChev.AnchorPoint = Vector2.new(1, 0.5)
                DChev.Position    = UDim2.new(1, -8, 0.5, 0)
                DChev.Size        = UDim2.new(0, 16, 0, 16)
                DChev.Image       = GetIcon("lucide-chevron-down")
                DChev.ImageColor3 = theme.Muted
                DChev.ZIndex      = 5

                -- Dropdown panel (overlays, high Z)
                local Panel = Instance.new("Frame", DropWrap)
                Panel.BackgroundColor3 = theme.Surface
                Panel.BorderSizePixel  = 0
                Panel.Position = UDim2.new(0, 0, 1, 4)
                Panel.Size     = UDim2.new(1, 0, 0, 0)
                Panel.ClipsDescendants = true
                Panel.Visible  = false
                Panel.ZIndex   = 20
                AddCorner(Panel, 6)
                AddStroke(Panel, theme.Border, 1)

                -- Search bar
                local SearchBox = Instance.new("TextBox", Panel)
                SearchBox.BackgroundColor3 = theme.InputBg
                SearchBox.BorderSizePixel  = 0
                SearchBox.Position = UDim2.new(0, 6, 0, 6)
                SearchBox.Size     = UDim2.new(1, -12, 0, 22)
                SearchBox.Font     = Enum.Font.Gotham
                SearchBox.PlaceholderText = "Search..."
                SearchBox.Text     = ""
                SearchBox.TextColor3  = theme.Text
                SearchBox.PlaceholderColor3 = theme.Muted
                SearchBox.TextSize = 11
                SearchBox.ClearTextOnFocus = false
                SearchBox.ZIndex = 22
                AddCorner(SearchBox, 5)
                AddPadding(SearchBox, 0, 0, 6, 6)

                local ItemScroll = Instance.new("ScrollingFrame", Panel)
                ItemScroll.BackgroundTransparency = 1
                ItemScroll.Position = UDim2.new(0, 6, 0, 32)
                ItemScroll.Size     = UDim2.new(1, -12, 1, -38)
                ItemScroll.ScrollBarThickness = 2
                ItemScroll.ScrollBarImageColor3 = theme.Accent
                ItemScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
                ItemScroll.ZIndex = 22
                AddList(ItemScroll, 2)

                local function UpdateDisplay()
                    if multi then
                        if #selected == 0 then
                            DVal.Text = "None"
                        elseif #selected <= 2 then
                            DVal.Text = table.concat(selected, ", ")
                        else
                            DVal.Text = #selected .. " selected"
                        end
                    end
                end

                local itemBtns = {}
                local function BuildItems(filter)
                    for _, b in pairs(itemBtns) do b:Destroy() end
                    itemBtns = {}
                    local count = 0
                    for _, item in ipairs(items) do
                        if filter == "" or string.find(item:lower(), filter:lower(), 1, true) then
                            local isSelected = false
                            for _, s in ipairs(selected) do
                                if s == item then isSelected = true; break end
                            end
                            local IBtn = Instance.new("TextButton", ItemScroll)
                            IBtn.BackgroundColor3 = isSelected and theme.AccentDim or theme.SurfaceHigh
                            IBtn.BorderSizePixel  = 0
                            IBtn.Size  = UDim2.new(1, 0, 0, 26)
                            IBtn.Font  = Enum.Font.Gotham
                            IBtn.Text  = "  " .. item
                            IBtn.TextColor3 = isSelected and theme.Text or theme.SubText
                            IBtn.TextSize   = 11
                            IBtn.TextXAlignment = Enum.TextXAlignment.Left
                            IBtn.ZIndex = 23
                            AddCorner(IBtn, 5)

                            IBtn.MouseEnter:Connect(function()
                                if not isSelected then
                                    TweenPlay(IBtn, {BackgroundColor3 = theme.SidebarItemHover}, 0.1)
                                end
                            end)
                            IBtn.MouseLeave:Connect(function()
                                if not isSelected then
                                    TweenPlay(IBtn, {BackgroundColor3 = theme.SurfaceHigh}, 0.1)
                                end
                            end)

                            IBtn.MouseButton1Click:Connect(function()
                                if multi then
                                    isSelected = not isSelected
                                    if isSelected then
                                        table.insert(selected, item)
                                        TweenPlay(IBtn, {BackgroundColor3 = theme.AccentDim}, 0.12)
                                        IBtn.TextColor3 = theme.Text
                                    else
                                        for i, v in ipairs(selected) do
                                            if v == item then table.remove(selected, i); break end
                                        end
                                        TweenPlay(IBtn, {BackgroundColor3 = theme.SurfaceHigh}, 0.12)
                                        IBtn.TextColor3 = theme.SubText
                                    end
                                    UpdateDisplay()
                                    task.spawn(cb, selected)
                                else
                                    selected = {item}
                                    DVal.Text = item
                                    task.spawn(cb, item)
                                    -- close
                                    isOpen = false
                                    TweenPlay(Panel, {Size = UDim2.new(1, 0, 0, 0)}, 0.18, Enum.EasingStyle.Quint)
                                    TweenPlay(DChev, {Rotation = 0}, 0.18)
                                    task.delay(0.18, function() Panel.Visible = false end)
                                end
                            end)
                            table.insert(itemBtns, IBtn)
                            count = count + 1
                        end
                    end
                    local panelH = math.min(count, MAX_VISIBLE) * 28 + 40
                    ItemScroll.CanvasSize = UDim2.new(0, 0, 0, count * 28)
                    if isOpen then
                        TweenPlay(Panel, {Size = UDim2.new(1, 0, 0, panelH)}, 0.15)
                    end
                end

                SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
                    BuildItems(SearchBox.Text)
                end)

                Header2.MouseButton1Click:Connect(function()
                    isOpen = not isOpen
                    if isOpen then
                        SearchBox.Text = ""
                        Panel.Visible  = true
                        BuildItems("")
                        local panelH = math.min(#items, MAX_VISIBLE) * 28 + 40
                        Panel.Size = UDim2.new(1, 0, 0, 0)
                        TweenPlay(Panel, {Size = UDim2.new(1, 0, 0, panelH)}, 0.22, Enum.EasingStyle.Back)
                        TweenPlay(DChev, {Rotation = 180}, 0.2)
                    else
                        TweenPlay(Panel, {Size = UDim2.new(1, 0, 0, 0)}, 0.18, Enum.EasingStyle.Quint)
                        TweenPlay(DChev, {Rotation = 0}, 0.18)
                        task.delay(0.18, function() Panel.Visible = false end)
                    end
                end)

                BuildItems("")

                local API = {}
                function API:Set(val)
                    if multi then
                        selected = type(val) == "table" and val or {val}
                    else
                        selected = {val}
                        DVal.Text = val
                    end
                    UpdateDisplay()
                end
                function API:Get() return multi and selected or selected[1] end
                function API:Refresh(newItems) items = newItems; BuildItems("") end
                return API
            end

