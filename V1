    -- ══════════════════════════════════════════════
    function Window:Notify(cfg2)
        local title    = cfg2.Title   or "Notice"
        local content  = cfg2.Content or ""
        local duration = cfg2.Time    or 5
        local icon     = cfg2.Icon    or "lucide-bell"
        local ntype    = cfg2.Type    or "default"  -- "default" | "success" | "error" | "warning"

        local accentColor = ({
            default = theme.Accent,
            success = theme.Positive,
            error   = theme.Negative,
            warning = theme.Warning,
        })[ntype] or theme.Accent

        -- Measure text height
        local textH = TextService:GetTextSize(content, 11, Enum.Font.Gotham, Vector2.new(242, 9999)).Y
        local targetH = math.max(62, textH + 48)

        local N = Instance.new("Frame", NotifHolder)
        N.BackgroundColor3 = theme.Surface
        N.BorderSizePixel  = 0
        N.Size = UDim2.new(1, 0, 0, 0)
        N.ClipsDescendants = false
        AddCorner(N, 8)
        AddStroke(N, accentColor, 1, 0.5)

        -- Left color bar
        local Bar = Instance.new("Frame", N)
        Bar.BackgroundColor3 = accentColor
        Bar.BorderSizePixel  = 0
        Bar.Size = UDim2.new(0, 3, 1, 0)
        AddCorner(Bar, 4)

        -- Top accent line
        local TLine = Instance.new("Frame", N)
        TLine.BackgroundColor3 = accentColor
        TLine.Size = UDim2.new(1, 0, 0, 2)
        TLine.BorderSizePixel = 0

        local NIcon = Instance.new("ImageLabel", N)
        NIcon.BackgroundTransparency = 1
        NIcon.Position = UDim2.new(0, 12, 0, 12)
        NIcon.Size     = UDim2.new(0, 18, 0, 18)
        NIcon.Image    = GetIcon(icon)
        NIcon.ImageColor3 = accentColor

        local NTitle = Instance.new("TextLabel", N)
        NTitle.BackgroundTransparency = 1
        NTitle.Position = UDim2.new(0, 36, 0, 10)
        NTitle.Size     = UDim2.new(1, -44, 0, 16)
        NTitle.Font     = Enum.Font.GothamBold
        NTitle.Text     = title
        NTitle.TextColor3 = theme.Text
        NTitle.TextSize   = 13
        NTitle.TextXAlignment = Enum.TextXAlignment.Left

        local NDesc = Instance.new("TextLabel", N)
        NDesc.BackgroundTransparency = 1
        NDesc.Position  = UDim2.new(0, 36, 0, 30)
        NDesc.Size      = UDim2.new(1, -44, 0, textH)
        NDesc.Font      = Enum.Font.Gotham
        NDesc.Text      = content
        NDesc.TextColor3 = theme.SubText
        NDesc.TextSize   = 11
        NDesc.TextWrapped = true
        NDesc.TextXAlignment = Enum.TextXAlignment.Left

        -- Progress bar
        local PBase = Instance.new("Frame", N)
        PBase.BackgroundColor3 = theme.TrackBg
        PBase.AnchorPoint = Vector2.new(0, 1)
        PBase.Position = UDim2.new(0, 8, 1, -4)
        PBase.Size     = UDim2.new(1, -16, 0, 2)
        PBase.BorderSizePixel = 0
        AddCorner(PBase, 100)

        local PFill = Instance.new("Frame", PBase)
        PFill.BackgroundColor3 = accentColor
        PFill.BorderSizePixel  = 0
        PFill.Size = UDim2.new(1, 0, 1, 0)
        AddCorner(PFill, 100)

        -- Animate in
        TweenPlay(N, {Size = UDim2.new(1, 0, 0, targetH)}, 0.3, Enum.EasingStyle.Back)

        -- Progress drain
        TweenPlay(PFill, {Size = UDim2.new(0, 0, 1, 0)}, duration - 0.3, Enum.EasingStyle.Linear)

        task.delay(duration, function()
            TweenPlay(N, {Size = UDim2.new(1, 0, 0, 0)}, 0.25, Enum.EasingStyle.Quint)
            task.delay(0.25, function() N:Destroy() end)
        end)
    end

