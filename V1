            -- ── Color Picker ──────────────────────
            function SectionAPI:CreateColorPicker(name, default, callback)
                local cb    = callback or function() end
                local color = default or Color3.fromRGB(139, 92, 246)
                local h, s, v = color:ToHSV()
                local isOpen = false

                local CWrap = Instance.new("Frame", EContainer)
                CWrap.BackgroundColor3 = theme.SurfaceHigh
                CWrap.BorderSizePixel  = 0
                CWrap.Size  = UDim2.new(1, 0, 0, 32)
                CWrap.ClipsDescendants = true
                AddCorner(CWrap, 6)
                AddStroke(CWrap, theme.Border, 1)

                local CHeader = Instance.new("TextButton", CWrap)
                CHeader.BackgroundTransparency = 1
                CHeader.Size = UDim2.new(1, 0, 0, 32)
                CHeader.Text = ""
                CHeader.AutoButtonColor = false

                local CNL = Instance.new("TextLabel", CHeader)
                CNL.BackgroundTransparency = 1
                CNL.Position = UDim2.new(0, 10, 0, 0)
                CNL.Size     = UDim2.new(0.7, 0, 1, 0)
                CNL.Font     = Enum.Font.GothamBold
