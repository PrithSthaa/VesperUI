        TweenPlay(tab._btn, {BackgroundColor3 = T.SidebarHover}, 0.18)
        TweenPlay(tab._bar, {BackgroundTransparency = 0, Size = UDim2.new(0,3,0.65,0)}, 0.22, Enum.EasingStyle.Back)
