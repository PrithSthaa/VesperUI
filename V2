            -- Element container
            local EBox = Instance.new("Frame", SBase)
            EBox.BackgroundTransparency = 1
            EBox.Position = UDim2.new(0,0,0,42)
            EBox.Size     = UDim2.new(1,0,0,0)
            EBox.AutomaticSize = Enum.AutomaticSize.Y
            AddPad(EBox, 8,10,10,10)
