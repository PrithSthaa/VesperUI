            STitle.TextSize   = 12
            STitle.TextXAlignment = Enum.TextXAlignment.Left

            -- Sub-header divider
            local SDiv = Instance.new("Frame", SBase)
            SDiv.BackgroundColor3 = T.Border
            SDiv.Position = UDim2.new(0,8,0,38)
            SDiv.Size     = UDim2.new(1,-16,0,1)
