            -- ══════════════════════════════════════
            function SecAPI:CreateLabel(cfg3)
                local text = type(cfg3)=="string" and cfg3 or (cfg3.Title or cfg3[1] or "")
                local body  = type(cfg3)=="table"  and cfg3.Content or nil

                local F = Instance.new("Frame", EBox)
