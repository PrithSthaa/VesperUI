--  SAVE MANAGER
-- ════════════════════════════════════════════════════════════════
--[[
    Usage:
        local SaveManager = Vesper.SaveManager
        SaveManager:SetFolder("MyHub/GameName")
        SaveManager:BuildConfigSection(SettingsTab)   -- adds Load/Save/Autoload UI to a tab
        SaveManager:LoadAutoloadConfig()              -- call at end of script
        SaveManager:IgnoreKeys({"MyToggle", "MyBind"}) -- skip these from saving
]]

Vesper.SaveManager = (function()
    local SM = {
        _folder     = "VesperConfigs",
        _ignored    = {},
        _autoload   = nil,
        _library    = nil,
    }

    local function GetWriteFile()
        -- writefile / readfile compatibility layer
        if not writefile then
            warn("[SaveManager] writefile not available – configs disabled.")
            return false
        end
        return true
    end

    local function EnsureFolder(path)
        if not isfolder(path) then pcall(function() makefolder(path) end) end
    end

    local function ConfigPath(name)
        return SM._folder .. "/" .. name .. ".json"
    end

    -- Serialize a Color3 to table
    local function SerColor(c) return {R=c.R, G=c.G, B=c.B} end
    local function DeserColor(t) return Color3.new(t.R, t.G, t.B) end

    function SM:SetFolder(path)
        self._folder = path
        EnsureFolder(path)
    end

    function SM:IgnoreKeys(list)
        for _, k in ipairs(list) do self._ignored[k] = true end
    end
    SM.IgnoreThemeSettings = function(self) end -- no-op, compat shim

    function SM:SetIgnoreIndexes(list)
        for _, k in ipairs(list) do self._ignored[k] = true end
    end

    function SM:SetLibrary(lib) self._library = lib end  -- compat shim

    -- Build a config table from current Options
        function SM:_Collect()
            local data = {}

            for key, elem in pairs(Vesper.Options) do
                if not (self._ignored and self._ignored[key]) then
                    
                    local val
                    if elem.GetState then
                        local success, result = pcall(function()
                            return elem:GetState()
                        end)
                        val = success and result or elem.Value
                    else
                        val = elem.Value
                    end

                    local t = typeof(val)

                    if t == "boolean" or t == "number" or t == "string" then
                        data[key] = val
                    elseif t == "table" then
                        data[key] = val
                    elseif t == "Color3" then
                        data[key] = SerColor(val)
                    elseif t == "EnumItem" then
                        data[key] = val.Name
                    end
                end
            end

            return data
        end

    -- Apply a config table back to Options
    function SM:_Apply(data)
        for key, val in pairs(data) do
            local elem = Vesper.Options[key]
            if elem and elem.SetValue then
                local t = type(val)
                if t == "table" and val.R ~= nil then
                    elem:SetValue(DeserColor(val))
                elseif t == "table" then
                    elem:SetValue(val)
                else
                    elem:SetValue(val)
                end
            end
        end
    end

    function SM:Save(name)
        if not GetWriteFile() then return end
        EnsureFolder(self._folder)
        local data = self:_Collect()
        local ok, err = pcall(function()
            writefile(ConfigPath(name), game:GetService("HttpService"):JSONEncode(data))
        end)
        if ok then
            if Vesper._window then
                Vesper._window:Notify({Title="Config Saved", Content='Saved as "'..name..'"', Type="success", Duration=3})
            end
        else
            warn("[SaveManager] Save failed:", err)
        end
    end

    function SM:Load(name)
        if not GetWriteFile() then return end
        local path = ConfigPath(name)
        if not isfile(path) then
            if Vesper._window then
                Vesper._window:Notify({Title="Config Not Found", Content='"'..name..'" does not exist.', Type="error", Duration=4})
            end
            return
        end
        local ok, data = pcall(function()
            return game:GetService("HttpService"):JSONDecode(readfile(path))
        end)
        if ok and data then
            self:_Apply(data)
            if Vesper._window then
                Vesper._window:Notify({Title="Config Loaded", Content='Loaded "'..name..'"', Type="success", Duration=3})
            end
        else
            warn("[SaveManager] Load failed:", data)
        end
    end

    function SM:Delete(name)
        if not GetWriteFile() then return end
        local path = ConfigPath(name)
        if isfile(path) then
            pcall(function() delfile(path) end)
        end
    end

    function SM:SetAutoload(name)
        self._autoload = name
        EnsureFolder(self._folder)
        pcall(function()
            writefile(self._folder .. "/_autoload.txt", name)
        end)
        if Vesper._window then
            Vesper._window:Notify({Title="Autoload Set", Content='"'..name..'" will load on next inject.', Duration=3})
        end
    end

    function SM:LoadAutoloadConfig()
        -- First check explicit autoload
        if self._autoload then self:Load(self._autoload); return end
        -- Then check file
        local path = self._folder .. "/_autoload.txt"
        if not GetWriteFile() then return end
        if isfile(path) then
            local ok, name = pcall(function() return readfile(path) end)
            if ok and name and name ~= "" then
                self._autoload = name
                task.delay(0.5, function() self:Load(name) end)
            end
        end
    end

    function SM:GetConfigs()
        if not GetWriteFile() then return {} end
        EnsureFolder(self._folder)
        local list = {}
        pcall(function()
            for _, f in ipairs(listfiles(self._folder)) do
                local name = f:match("([^/\\]+)%.json$")
                if name then table.insert(list, name) end
            end
        end)
        return list
    end

    -- Builds a config section UI inside a given tab
    function SM:BuildConfigSection(tabAPI)
        local sec = tabAPI:CreateSection({ Title = "Configuration", Icon = "lucide-save" })
        local self2 = self

        -- Config name input
        local nameInput = sec:CreateTextBox("_cfgName", {
            Title       = "Config Name",
            Placeholder = "my-config",
            Default     = "default",
            Finished    = false,
        })

        -- Save button
        sec:CreateButton({
            Title       = "Save Config",
            Description = "Saves all current values",
            Callback    = function()
                local n = nameInput:GetState()
                if n and n ~= "" then self2:Save(n) end
            end,
        })

        -- Load button
        sec:CreateButton({
            Title       = "Load Config",
            Description = "Loads the named config",
            Callback    = function()
                local n = nameInput:GetState()
                if n and n ~= "" then self2:Load(n) end
            end,
        })

        -- Set as autoload
        sec:CreateButton({
            Title       = "Set as Autoload",
            Description = "Automatically loads on next inject",
            Callback    = function()
                local n = nameInput:GetState()
                if n and n ~= "" then self2:SetAutoload(n) end
            end,
        })

        -- Clear autoload
        sec:CreateButton({
            Title    = "Clear Autoload",
            Callback = function()
                self2._autoload = nil
                pcall(function() delfile(self2._folder .. "/_autoload.txt") end)
                if Vesper._window then
                    Vesper._window:Notify({Title="Autoload Cleared", Duration=2})
                end
            end,
        })

        -- Refresh list + dropdown for loading by selection
        local function GetConfigs() return self2:GetConfigs() end

        local configDrop = sec:CreateDropdown("_cfgDrop", {
            Title    = "Saved Configs",
            Values   = GetConfigs(),
            Multi    = false,
            Callback = function(v) nameInput:SetValue(v) end,
        })

        sec:CreateButton({
            Title    = "Refresh List",
            Callback = function()
                configDrop:Refresh(GetConfigs())
            end,
        })

        sec:CreateButton({
            Title       = "Delete Config",
            Description = "Permanently deletes the named config",
            Callback    = function()
                local n = nameInput:GetState()
                if n and n ~= "" then
                    self2:Delete(n)
                    configDrop:Refresh(GetConfigs())
                    if Vesper._window then
                        Vesper._window:Notify({Title="Config Deleted", Content='"'..n..'" removed.', Type="warning", Duration=3})
                    end
                end
            end,
        })
    end

    return SM
end)()

-- ════════════════════════════════════════════════════════════════
return Vesper
